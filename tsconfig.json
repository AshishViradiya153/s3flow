{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "@ashishviradiya153/s3download": ["./src/index.ts"],
      "@ashishviradiya153/s3download/platform": ["./src/platform.ts"],
      "@ashishviradiya153/s3download/bullmq": ["./src/bullmq.ts"],
      "@ashishviradiya153/s3download/gcs": ["./src/gcs.ts"],
      "@ashishviradiya153/s3download/azure-blob": ["./src/azure-blob.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "verbatimModuleSyntax": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "examples/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
